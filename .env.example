# ── admin-frontend environment variables ──────────────────────────────────────
# Copy this file to .env.local for local development.
# In CI/CD (e.g. GitHub Actions or CodeBuild), set these as environment variables
# prefixed with REACT_APP_ so Create React App inlines them at build time.

# ── AWS Cognito ────────────────────────────────────────────────────────────────
# The User Pool ID (e.g. us-east-1_XXXXXXXXX)
REACT_APP_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

# The App Client ID for the admin portal (a SEPARATE client from the web-frontend
# client so you can configure different callback URLs and scopes independently).
REACT_APP_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# The Cognito Hosted UI domain (no trailing slash).
# Format: https://<your-domain>.auth.<region>.amazoncognito.com
REACT_APP_COGNITO_AUTH_URL=https://your-domain.auth.us-east-1.amazoncognito.com

# The URL this app is deployed to — must exactly match a Callback URL registered
# in the Cognito App Client (e.g. https://admin.yourdomain.com).
# For local dev: http://localhost:3001
REACT_APP_REDIRECT_URI=https://admin.yourdomain.com

# ── Backend API ────────────────────────────────────────────────────────────────
# The API Gateway invoke URL (no trailing slash).
# e.g. https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod
REACT_APP_API_GATEWAY_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod
